# Backend API URL - Thay đổi URL này với backend API của bạn
VITE_BACKEND_URL=http://localhost:5000

# WebSocket URL - Thay đổi URL này với WebSocket server của bạn  
VITE_SOCKET_URL=ws://localhost:5000

# MinIO/Storage URL - Thay đổi URL này với storage service của bạn
VITE_MINIO_URL=http://localhost:9000

# Enable logs (true = show logs in development, false = hide logs in production)
VITE_LOG=true

# Traffic Status Labels (Level of Service - LOS)
# Các giá trị này là single source of truth cho toàn frontend
# Nếu không set, fallback mặc định trong src/lib/los-config.ts sẽ được dùng
VITE_LOS_FREE_FLOW=Thông thoáng
VITE_LOS_SMOOTH=Trôi chảy
VITE_LOS_MODERATE=Vừa phải
VITE_LOS_HEAVY=Đông đúc
VITE_LOS_CONGESTED=Ùn tắc
